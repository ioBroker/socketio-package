{
  "name": "@iobroker/socketio-server",
  "version": "7.1.3",
  "description": "This package allows to communicate different web applications with ioBroker via socket.io library.",
  "author": {
    "name": "bluefox",
    "email": "dogafox@gmail.com"
  },
  "homepage": "https://github.com/ioBroker/socketio-package",
  "keywords": [
    "ioBroker",
    "web"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ioBroker/socketio-package"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "dependencies": {
    "@iobroker/socket-classes": "^2.3.1",
    "@iobroker/webserver": "^1.4.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "socket.io": "^2.5.1"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/types": "^7.2.2",
    "@iobroker/ws-server": "^4.4.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.19.21",
    "@types/passport": "^1.0.17",
    "@types/socket.io": "^2.1.13",
    "socket.io-client": "^2.5.0",
    "typescript": "~6.0.3"
  },
  "bugs": {
    "url": "https://github.com/ioBroker/socketio-package/issues"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./socket.io.js": "./build/lib/socket.io.js",
    "./package.json": "./package.json"
  },
  "files": [
    "build/",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node tasks.ts",
    "lint": "eslint -c eslint.config.mjs",
    "release": "release-script",
    "release-patch": "release-script patch --yes",
    "release-minor": "release-script minor --yes",
    "release-major": "release-script major --yes",
    "update-packages": "npx -y npm-check-updates --upgrade",
    "npm": "npm i"
  },
  "license": "MIT",
  "readmeFilename": "README.md"
}
